# Optional: enables LLM-assisted series clustering across language variants
# (e.g. simplified vs traditional Chinese, Japanese vs romaji). Without a key
# the app falls back to heuristic grouping silently.
#
# Any Anthropic-compatible endpoint works. Pick one:
#
# MiniMax:
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.minimaxi.com/anthropic
# LLM_MODEL=MiniMax-M2.7
#
# Kimi:
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.kimi.com/coding
# LLM_MODEL=kimi-k2-turbo-preview
#
# Legacy MINIMAX_* vars are still honored as fallbacks.
LLM_API_KEY=
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_MODEL=MiniMax-M2.7
