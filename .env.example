# Optional: enables LLM-assisted series clustering across language variants
# (e.g. simplified vs traditional Chinese, Japanese vs romaji). All three
# must be set to enable the refine pass; otherwise heuristic grouping runs
# alone. Any Anthropic-compatible endpoint works. Example values:
#
# Kimi:     LLM_BASE_URL=https://api.kimi.com/coding       LLM_MODEL=kimi-k2.5
# MiniMax:  LLM_BASE_URL=https://api.minimaxi.com/anthropic LLM_MODEL=MiniMax-M2.7
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
