# Optional: enables LLM-assisted series clustering across language variants
# (e.g. simplified vs traditional Chinese, Japanese vs romaji). Without a key
# the app falls back to heuristic grouping silently.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7
